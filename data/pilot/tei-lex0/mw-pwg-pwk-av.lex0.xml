      <entry xml:id="mw-pwg-pwk-av-entry" xml:lang="sa">
        <form type="lemma">
          <orth notation="SLP1" xml:lang="sa-Latn-x-SLP1" cert="high" resp="#source">av</orth>
        </form>
        <gramGrp>
          <pos norm="verb" cert="high" resp="#machine">verb</pos>
          <gram type="verb-class" cert="high" resp="#source">1</gram>
        </gramGrp>
        <sense xml:id="mw-pwg-pwk-av-sense-1" n="1">
          <def xml:lang="en" cert="high" resp="#machine">to drive, impel, animate</def>
          <bibl type="named-source" source="#dict-mw" cert="high" resp="#source"><abbr>RV.</abbr></bibl>
        </sense>
        <sense xml:id="mw-pwg-pwk-av-sense-2" n="2">
          <def xml:lang="en" cert="high" resp="#machine">to promote, favour</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-av-sense-3" n="3">
          <def xml:lang="en" cert="high" resp="#machine">to offer</def>
          <bibl type="named-source" source="#dict-mw" cert="high" resp="#source"><abbr>RV. iv, 44, 6</abbr></bibl>
        </sense>
        <sense xml:id="mw-pwg-pwk-av-sense-4" n="4">
          <def xml:lang="en" cert="high" resp="#machine">to lead or bring to</def>
          <bibl type="named-source" source="#dict-mw" cert="high" resp="#source"><abbr>RV.</abbr></bibl>
        </sense>
        <sense xml:id="mw-pwg-pwk-av-sense-5" n="5">
          <def xml:lang="en" cert="high" resp="#machine">to be pleased with, like, accept favourably</def>
          <bibl type="named-source" source="#dict-mw" cert="high" resp="#source"><abbr>RV.</abbr></bibl>
        </sense>
        <sense xml:id="mw-pwg-pwk-av-sense-6" n="6">
          <def xml:lang="en" cert="high" resp="#machine">to guard, defend, protect, govern, BhP</def>
        </sense>
