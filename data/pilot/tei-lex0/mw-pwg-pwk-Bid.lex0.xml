        <form type="lemma">
          <orth notation="SLP1" xml:lang="sa-Latn-x-SLP1" cert="high" resp="#source">Bid</orth>
        </form>
        <gramGrp>
          <pos norm="verb" cert="high" resp="#machine">verb</pos>
          <gram type="verb-class" cert="high" resp="#source">7</gram>
        </gramGrp>
        <sense xml:id="mw-pwg-pwk-Bid-sense-1" n="1">
          <def xml:lang="en" cert="high" resp="#machine">to split, cleave, break, cut or rend asunder, pierce, destroy, etc. etc</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-Bid-sense-2" n="2">
          <def xml:lang="en" cert="high" resp="#machine">to pass through</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-Bid-sense-3" n="3">
          <def xml:lang="en" cert="high" resp="#machine">to disperse</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-Bid-sense-4" n="4">
          <def xml:lang="en" cert="high" resp="#machine">to transgress, violate</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-Bid-sense-5" n="5">
          <def xml:lang="en" cert="high" resp="#machine">to open, expand</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-Bid-sense-6" n="6">
          <def xml:lang="en" cert="high" resp="#machine">to loosen, disentangle, dissolve</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-Bid-sense-7" n="7">
          <def xml:lang="en" cert="high" resp="#machine">to disturb, interrupt, stop</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-Bid-sense-8" n="8">
          <def xml:lang="en" cert="high" resp="#machine">to disclose</def>
        </sense>
