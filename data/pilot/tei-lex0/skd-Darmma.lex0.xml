      <entry xml:id="skd-Darmma" xml:lang="sa">
        <form type="lemma">
          <orth notation="SLP1" xml:lang="sa-Latn-x-SLP1" cert="high" resp="#source">Darmma</orth>
        </form>
        <gramGrp>
          <pos norm="noun" cert="high" resp="#machine">noun</pos>
          <gen norm="masculine" cert="high" resp="#source">masculine</gen>
          <gen norm="neuter" cert="high" resp="#source">neuter</gen>
        </gramGrp>
        <etym xml:id="skd-Darmma-etym" type="derivation"><lbl>from</lbl> <mentioned xml:lang="sa">Dṛ</mentioned> <bibl><title>Uṇādisūtra 1.139</title></bibl></etym>
        <sense xml:id="skd-Darmma-sense-1" n="1">
          <def xml:lang="sa" cert="high" resp="#source">śubhādṛṣṭam</def>
          <cit type="example" xml:lang="sa">
            <quote xml:space="preserve">eka eva suhṛd dharmo nidhane &apos;py anuyāti yaḥ</quote>
            <bibl><title>Hitopadeśa</title><citedRange>1.59</citedRange></bibl>
          </cit>
        </sense>
        <sense xml:id="skd-Darmma-sense-2" n="2">
          <def xml:lang="sa" cert="high" resp="#source">paryāya: puṇyam, śreyaḥ, sukṛtam, vṛṣaḥ</def>
          <bibl><author>Amara</author><citedRange>1.4.24</citedRange></bibl>
          <note type="model-loss" resp="#source">The paryāya synonym run and its authority (ity amaraḥ) are a single iti-unit in the source: sense enumeration and source attestation are one construction, not separable into def + bibl.</note>
        </sense>
        <sense xml:id="skd-Darmma-sense-3" n="3">
          <def xml:lang="en" cert="high" resp="#source">law; nature; custom; likeness; sacrifice; non-violence; an Upaniṣad</def>
          <bibl><title>Medinī</title></bibl>
        </sense>
        <sense xml:id="skd-Darmma-sense-4" n="4">
          <def xml:lang="en" cert="high" resp="#source">(in the neuter) a gift, charity</def>
          <bibl><author>Hemacandra</author></bibl>
        </sense>
        <note type="model-loss" resp="#source">Indigenous kosa entry: senses are provided explicitly (curated) because the iti-unit/paryāya structure of Sanskrit-to-Sanskrit lexica is not yet parsed by the pilot&apos;s MW-tuned extractor. A kosa sense-boundary parser is slice 3.</note>
