          <def xml:lang="en" cert="high" resp="#machine">to go, move, tend</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-ac-sense-2" n="2">
          <def xml:lang="en" cert="high" resp="#machine">to honour</def>
        </sense>
