        <form type="lemma">
          <orth notation="SLP1" xml:lang="sa-Latn-x-SLP1" cert="high" resp="#source">vi</orth>
        </form>
        <sense xml:id="mw-pwg-pwk-vi-sense-1" n="1">
          <def xml:lang="en" cert="high" resp="#machine">sometimes it gives a meaning opposite to the idea contained in the simple root ( e.g. √, ‘to buy’</def>
        </sense>
        <sense xml:id="mw-pwg-pwk-vi-sense-2" n="2">
