  csl:sourceDictionary "fri" ;
  skos:definition "to, towards, against, into, on, upon, over, for, for the sake of"@en ;
  skos:definition "к, против, до, в, на, над, ради"@ru ;
  skos:definition "k, proti, do, v, na, nad, kvůli"@cs .

<https://sanskrit-lexicon.github.io/csl-standards/id/case/mw-pwg-pwk%3AaBi-mw11185.5#sense-ben-1> a ontolex:LexicalSense ;
