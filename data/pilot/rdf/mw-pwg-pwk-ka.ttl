  ontolex:isSenseOf <https://sanskrit-lexicon.github.io/csl-standards/id/case/mw-pwg-pwk%3Aka> ;
  csl:sourceDictionary "mw" ;
  skos:definition "and are not so common, but the latter is often found in ( e.g., any one"@en .

