      "csl:pageColumn": "2-068-c",
      "rdf:value": "<L>28111<pc>2-068-c<k1>ku<k2>ku<h>3\n<hom>3.</hom> {#ku#}¦ <lex>f.</lex>\n<div n=\"1\">— 1〉 {%die Erde%} <ls>ĀRYABH. 2,1</ls>. {%Land, Erdboden%} <ls>Spr. 7789</ls>.\n<div n=\"1\">— 2〉 {%die Basis eines Dreiecks%} (<ls>Comm. zu ĀRYABH. 2,8</ls>) oder {%einer anderen Figur%}.\n<div n=\"1\">— 3〉 <ab>Bez.</ab> {%der Zahl eins%}.\n<LEND>"
    },
