      "rdf:value": "<L>1734<pc>077<k1>ku<k2>ku\nku pref.\n<div n=\"1\"/>1 <lang n=\"czech\">vyjadřuje špatnost, malost, nedostatek atd.</lang>\n<div n=\"1\"/>2 <lang n=\"russian\">выражает низость, ничтожество, недостаток и т.д.</lang>\n<div n=\"1\"/>3 <lang n=\"english\">it implies badness, littleness, deficiency &c.</lang>\n<LEND>"
    },
