      "csl:pageColumn": "1-0817",
      "rdf:value": "<L>10344<pc>1-0817<k1>il<k2>il\n{#il#}¦, {#ila/yati#}; <ab>imperf.</ab> {#ElayIt#}; <ab>partic.</ab> {#ilita/#}; {%stillhalten, sich nicht rühren; zur Ruhe kommen%}: {#tizWa^te\\laya^tA\\#} (so mehrere <ab>Handschrr.</ab>, auch\n<ls>AV. 1,17,4</ls>; <ls>MÜLLER</ls> schreibt {#iLa˚) su ka^m#} {%stehet, haltet still!%}\n<ls>ṚV. 1,191,6.</ls> {#ka\\TaM vAto\\ nela^yati ka\\TaM na ra^mate\\ mana^H#}\n<ls>AV. 10,7,37.</ls>\n<ls>TS. 6,4,2,6.</ls>\n<ls>AIT. BR. 5,25.</ls> {#ilitA hi Sere#}\n<ls>ŚAT. BR. 2,3,1,3.</ls> <ls n=\"ŚAT. BR.\">3,9,2,5.</ls> {#AsAM devatAnAM yAM yAM kAmayate sA BUtvelayati#}\n<ls n=\"ŚAT. BR.\">10,3,3,8.</ls> {#elayati#}\n<ls>P. 3,1,51.</ls> {#kAmamElayIt#} (<ab>angebl.</ab> <ab>ved.</ab> <ab>aor.</ab>, entsprechend dem klass. {#Elilat#})\n<ls>Sch. 7,2,5</ls>, <ab>Sch.</ab>\n<ls>VOP. 8,86.</ls> <ls n=\"VOP.\">18,1.</ls> Nach <ls>DHĀTUP. 32,118</ls> bedeutet {#il, ela/yati#} {%werfen%}; nach\n<ls n=\"DHĀTUP.\">28,65</ls> {#il, ila/ti#} {%schlafen; werfen; gehen.%} Den <ab>imperat.</ab> {#ila#} ({%komme%}) haben wir\n<ls>HARIV. 620</ls> zur Erklärung des Ursprungs des <ab>N. pr.</ab> {#ilA#} (<ab>s. d.</ab>): {#tAmiletyeva hovAca manurdaRqaDarastadA . anugacCasva mAM Badre tAmilA pratyuvAca ha .#}\n<div n=\"p\">— {#ava#} {%zur Ruhe kommen%}: {#tOvi^li\\ke 've^la\\yAvA\\yamE^la\\ba E^layIt#}\n<ls>AV. 6,16,3.</ls>\n<LEND>"
    },
