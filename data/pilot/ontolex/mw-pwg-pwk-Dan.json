      "rdf:value": "<L>54354<pc>3-140-b<k1>Dan<k2>Dan<h>1\n<hom>1.</hom> √{#Dan#}¦ {#daDanti#}\n<div n=\"1\">— 1〉 {%in Bewegung setzen, laufen, machen%}. Zu belegen nur {#daDa/nat#}.\n<div n=\"1\">— 2〉 {#Dnye#}.\n<div n=\"m\">— <ab>Caus.</ab> {#Dana/yati, ˚te#}\n<div n=\"1\">— 1〉 <ab>Act.</ab> <ab>Med.</ab> {%in Bewegung setzen%}.\n<div n=\"1\">— 2〉 <ab>Med.</ab> {%sich in Bewegung setzen, laufen%}.\n<div n=\"p\">— Mit {#pra#} {%hervorlaufen, -strömen, quellen,%} Nur {#˚daDanyus#} zu belegen.\n<LEND>"
    },
