      "rdf:value": "<L>79433<pc>4-259-c<k1>BAma<k2>BA/ma<h>2\n<hom>2.</hom> {#BA/ma#}¦\n<div n=\"1\">— 1〉 <lex>m.</lex>\n<div n=\"2\">— a〉 {%Grimm, Wuth, Zorn%}.\n<div n=\"2\">— b〉 <ab>N. pr.</ab> eines Mannes <ls>PISCHEL, de Gr. pr. 27</ls>.\n<div n=\"1\">— 2〉 <lex>f.</lex> {#BAmA#}\n<div n=\"2\">— a〉 {%eine leidenschaftliche Frau%}.\n<div n=\"2\">— b〉 <ab>N. pr.</ab> einer der Frauen <is>Kṛṣṇa</is>ʼs = {#satyaBAmA#} <ls>Comm. zu TS. PRĀT.</ls>\n<LEND>"
    },
