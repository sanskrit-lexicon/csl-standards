      "rdf:value": "<L>54566<pc>5-0248<k1>BAma<k2>BA/ma<h>2\n2. {#BA/ma#}¦ (von {#BAm)#}\n<div n=\"1\"> 1) <lex>m.</lex> {%Grimm, Wuth, Zorn%}\n<ls>NAIGH. 2,13.</ls>\n<ls>TRIK. 1,1,128.</ls>\n<ls>H. an. 2,330.</ls>\n<ls>MED. m. 21.</ls> <ls>VIŚVA</ls> bei <ls>UJJVAL.</ls> zu <ls>UṆĀDIS. 1,139.</ls> {#vaDI^M vf\\traM ma^ruta indri\\yeRa\\ svena\\ BAme^na tavi\\zo ba^BU\\vAn#}\n<ls>ṚV. 1,165,8.</ls> {#dA\\na\\vasya\\ BAma\\M vajre^Ra\\ ni ja^GAna#}\n<ls n=\"ṚV.\">5,32,4.</ls> {#tvaM hi ma^nyo a\\BiBU^tyojAH svaya\\MBUrBAmo^ aBimAtizA\\haH#}\n<ls n=\"ṚV.\">10,83,4.</ls> {#namo^ ganDa\\rvasya\\ mana^se\\ (namase#} die <ab>Hdschrr.</ab>) {#namo\\ BAmA^ya\\ cakzu^ze ca kfRmaH#}\n<ls>AV. 14,2,35.</ls> <ls n=\"AV.\">18,4,82.</ls>\n<ls>VS. 18,4.</ls> <ls n=\"VS.\">20,6.</ls> <ls n=\"VS.\">21,39.</ls> <ls n=\"VS. 21,\">56.</ls>\n<ls>ŚAT. BR. 12,7,1,7.</ls>\n<div n=\"1\">— 2) <lex>f.</lex> {#A#}\n<div n=\"2\"> a) {%eine leidenschaftliche Frau%}\n<ls>ŚABDAR.</ls> im <ls>ŚKDR.</ls>\n<div n=\"2\">— b) = {#satyaBAmA#} <ab>N. pr.</ab> einer der Frauen <is>Kṛṣṇa's</is>\n<ls>KATHĀS. 39,197.</ls>\n<LEND>"
    },
