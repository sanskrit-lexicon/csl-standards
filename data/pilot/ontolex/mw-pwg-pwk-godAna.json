      "rdf:value": "<L>67127<pc>365,1<k1>godAna<k2>go—dA/na<h>2<e>3\r\n<hom>2.</hom> <s>go—dA/na</s> , ¦ &c. see <ab>s.v.</ab>\r\n<LEND>"
    },
    {
      "@id": "https://sanskrit-lexicon.github.io/csl-standards/id/case/mw-pwg-pwk%3AgodAna#record-pwg",
      "@type": "csl:SourceRecord",
