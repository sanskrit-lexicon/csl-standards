      "csl:pageColumn": "2-180-b",
      "rdf:value": "<L>36570<pc>2-180-b<k1>godAna<k2>godA/na\n{#godA/na#}¦ <lex>n.</lex>\n<div n=\"1\">— 1〉 {%das Schenken von Kühen%}.\n<div n=\"1\">— 2〉 {%Backenbart%}. {#˚karman#} <lex>n.</lex>, {#˚maNgala#} <lex>n.</lex>, {#˚viDi#} <lex>m.</lex> und {#godAna#} schlechtweg (<ls>ĀŚV. GṚHY. 1,18,1</ls>. <ls>GAUT.</ls>) {%eine <ab>best.</ab> mit dem Backenbart vorgenommene Ceremonie%}.\n<LEND>"
    },
