      "csl:pageColumn": "5-190-b",
      "rdf:value": "<L>94230<pc>5-190-b<k1>riP<k2>riP\n√{#riP#}¦, {#riPa/ti#}, {#rePati#} (mit {#A#})\n<div n=\"1\">— 1〉 {%knurren%}.\n<div n=\"1\">— 2〉 {#riPyate#} {%geschnarrt werden, die Aussprache des r haben%} oder {%bekommen%}. {#riPita#} {%geschnarrt, als r ausgesprochen%}. — Die indischen Autoritäten geben der Wurzel die Bedeutungen {#kaTana#} ({#katTana#}), {#yudDa#}, {#nindA#}, {#hiMsA#}, {#dAna#} und {#kleSa#}.\n<div n=\"p\">— Mit {#vyapa#} {%umreissen%} (also {#riP#} = {#riK#} = {#liK#}). {#vyapariPantAvivottaravediM parikrAmataH#} <ls>ĀPAST. ŚR. 12,22,7</ls> = {#viliKantO#} <ab>Comm.</ab>\n<div n=\"p\">— Mit {#ava#} <ab>dass.</ab>\n<div n=\"p\">— Mit {#A#} {%schnarchen%}.\n<div n=\"p\">— Mit {#vi#}, {#viriPita#} {%der r-Aussprache [Page5-190-c] verlustig%}.\n<LEND>"
