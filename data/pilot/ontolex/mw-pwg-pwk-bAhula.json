      "rdf:value": "<L>145010<pc>730,3<k1>bAhula<k2>bAhula<h>1<e>2\r\n<hom>1.</hom> <s>bAhula</s> ¦ <lex>n.</lex> (for <hom>2.</hom> See below) armour for the arms, <ls>L.</ls><info lex=\"n\"/>\r\n<LEND>"
    },
    {
      "@id": "https://sanskrit-lexicon.github.io/csl-standards/id/case/mw-pwg-pwk%3AbAhula#record-pwg",
