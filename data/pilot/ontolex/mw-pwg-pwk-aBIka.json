      "csl:pageColumn": "1-0354",
      "rdf:value": "<L>4842<pc>1-0354<k1>aBIka<k2>aBI/ka<h>2\n2. {#aBI/ka#}¦ (von {#aYc#} mit {#aBi#}; <ab>vgl.</ab> {#anUka, apAka, pratIka#}) <lex>n.</lex> {%das Zusammentreffen, Widerstand%}: {#prAva\\nmanu\\M dasya^ve kara\\BIka^m#} . Davon <ab>loc.</ab> {#aBI/ke#} (mit Ausnahme von\n<ls>ṚV. 1,119,8.</ls> <ls n=\"ṚV.\">10,133,1.</ls> stets am Ende des <is>Pāda</is>)\n<ls>NAIGH. 2,17.</ls> <ls n=\"NAIGH.\">3,29.</ls>\n<ls>NIR. 3,20.</ls>\n<div n=\"1\"> 1) <lex>adv.</lex>\n<div n=\"2\"> a) {%beim Zusammentreffen, gleichzeitig, rechtzeitig%}: {#ma\\DyA yatkartva\\maBa^vada\\BIke\\ kAma^M kfRvA\\ne pi\\tari^ yuva\\tyAm#}\n<ls>ṚV. 10,61,6.</ls> {#saM yadviSo 'va^vftranta yu\\DmA Adinnema^ indrayante a\\BIke^#}\n<ls n=\"ṚV.\">4,23,4.</ls> {#tA no\\ yAma^nnuruzyatAma\\BIke^#}\n<ls n=\"ṚV.\">7,85,1.</ls> <ls n=\"ṚV.\">1,118,5.</ls> <ls n=\"ṚV. 1,\">119,8.</ls> <ls n=\"ṚV.\">10,55,1.</ls>\n<div n=\"2\">— b) {%im Augenblick, alsbald%}: {#sa\\dyo dasyU\\npra mf^Ra ku\\tsyena\\ pra sUra^Sca\\kraM vf^hatAda\\BIke^#}\n<ls>ṚV. 4,16,12.</ls> {#aha\\nnindro\\ ada^hada\\gniri^ndo pu\\rA dasyU^nma\\DyaMdi^nAda\\BIke^#}\n<ls n=\"ṚV. 4,\">28,3.</ls> <ls n=\"ṚV.\">6,24,10.</ls> <ls n=\"ṚV.\">7,18,24.</ls> <ls n=\"ṚV.\">10,38,4.</ls> <ls n=\"ṚV. 10,\">133,1.</ls>\n<div n=\"1\">— 2) <ab>praep.</ab> mit <ab>vorang.</ab> <ab>abl.</ab>\n<div n=\"2\"> a) {%von — her, aus%}: {#A\\sno vfka^sya\\ varti^kAma\\BIke^ (amumuktam)#}\n<ls>ṚV. 1,116,14.</ls> {#Suci\\ reto\\ nizi^kta\\M dyOra\\BIke^#}\n(wo {#dyOH#}, das auch <ls>VS. 33,11.</ls> steht, als <ab>abl.</ab> zu nehmen ist; richtig <ls>MAHĪDH.</ls> zu <ab>d. St.</ab>)\n<ls n=\"ṚV. 1,\">71,8.</ls>\n<div n=\"2\">— b) {%aus Anlass von, wegen%}: {#ma\\haSci^dagna\\ ena^so a\\BIke^ U\\rvAdde\\vAnA^mu\\ta martyA^nAm . mA te\\ saKA^ya\\H sada\\midri^zAma#}\n<ls n=\"ṚV.\">4,12,5.</ls>\n<div n=\"2\">— c) {%vor%} (bei <ab>Zeitww.</ab> des {%Schützens, Sichrettens)%}: {#tUrva^tAM narA duri\\tAda\\BIke^#}\n<ls>ṚV. 6,50,10.</ls> {#pA\\hi va^jrivo #}\n[Page1-0355]\n{# duri\\tAda\\BIke^#}\n<ls n=\"ṚV.\">1,121,14.</ls> {#ko vA^M ma\\haSci\\ttyaja^so a\\BIke^ uru\\zyata^M mADvI dasrA na U\\tI#}\n<ls n=\"ṚV.\">4,43,4.</ls>\n<LEND>"
