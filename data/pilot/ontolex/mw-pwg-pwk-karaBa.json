      "rdf:value": "<L>24638<pc>2-022-c<k1>karaBa<k2>karaBa<h>1\n<hom>1.</hom> {#karaBa#}¦\n<div n=\"1\">— 1〉 <lex>m.</lex>\n<div n=\"2\">— a〉 {%Elephantenrüssel%} <ls>MBH. 3,280,46</ls>.\n<div n=\"2\">— b〉 {%Kamel%}.\n<div n=\"2\">— c〉 {%Kameljunges%}.\n<div n=\"2\">— d〉 {%Elephantenjunges%}. Auch {#kari˚#}.\n<div n=\"2\">— e〉 {%Mittelhand%}.\n<div n=\"2\">— f〉 {%ein Sänger, der beim Singen eine Grube in der Stirn bildet,%} <ls>S. S. S. 117</ls>.\n<div n=\"2\">— g〉 *{%ein <ab>best.</ab> Parfum%}.\n<div n=\"2\">— h〉 *{%Wand%} <ls>GAL.</ls>\n<div n=\"2\">— i〉 <ab>Bein.</ab> <is>Dantavakra</is>ʼs.\n<div n=\"1\">— 2〉 *<lex>f.</lex> {#A#} {%Fennich%} <ls>GAL.</ls>\n<div n=\"1\">— 3〉 *<lex>f.</lex> {#I#}\n<div n=\"2\">— a〉 {%Kamelweibchen%}.\n<div n=\"2\">— b〉 {%<bot>Tragia involucrata</bot>%}.\n<LEND>"
