      "rdf:value": "<L>90743<pc>6-0978<k1>vi<k2>vi<h>1\n1. {#vi#}¦ <lex>m.</lex>\n<ls>UṆĀDIS. 4,133.</ls> <ab>nom.</ab> <ab>sg.</ab> {#vis#} und {#ves#} (\n<ls>ṚV. 6,3,5.</ls> <ls n=\"ṚV.\">1,173,1.</ls> <ls n=\"ṚV.\">3,54,6.</ls> <ls n=\"ṚV.\">9,72,5.</ls> <ls n=\"ṚV.\">10,33,2</ls>), <ab>acc.</ab> {#vim#}, <ab>gen.</ab> <ab>abl.</ab> {#ves#}; <ab>nom.</ab> und <ab>acc.</ab> <ab>pl.</ab> {#va/yas#} (\n<ls>ṚV. 1,104,1</ls>), {#vi/Bis, vi/Byas, vInA/m#} . {%Vogel%}\n<ls>NIR. 2,6.</ls>\n<ls>AK. 2,5,33.</ls>\n<ls>H. 1316.</ls>\n<ls>HALĀY. 2,83.</ls> {#mA mADi^ pu\\tre vimi^va graBIzwa#}\n<ls>ṚV. 2,29,5.</ls> <ls n=\"ṚV. 2,\">38,7.</ls> {#utte\\ vaya^Scidvasa\\tera^paptan#}\n<ls n=\"ṚV.\">6,64,6.</ls> {#yadvA\\M raTo\\ viBi\\zpatA^t#} der <is>Aśvin</is>\n<ls n=\"ṚV.\">1,46,3.</ls> <ls n=\"ṚV.\">8,29,8.</ls> {#vayo 'SvA^H#} {%fliegende Rosse%}\n<ls n=\"ṚV.\">1,104,1.</ls> <ls n=\"ṚV. 1,\">117,14.</ls> <ls n=\"ṚV.\">6,63,7.</ls> {#vI\\nAM pa\\dam#}\n<ls n=\"ṚV.\">1,25,7.</ls> {#pa\\daM veH#}\n<ls n=\"ṚV. 1,\">164,7.</ls> <ls n=\"ṚV.\">3,5,5.</ls> <ls n=\"ṚV. 3,5,\">6.</ls> <ls n=\"ṚV. 3,\">7,7.</ls> <ls n=\"ṚV.\">4,5,8.</ls> <ls n=\"ṚV.\">10,5,1.</ls> {#mA\\tA pu\\trEradi^ti\\rDAya^se\\ veH#}\n<ls n=\"ṚV.\">1,72,9.</ls> <ls n=\"ṚV.\">6,48,17.</ls> {#pra su za viByo\\ vira^stu#}\n<ls n=\"ṚV.\">4,26,4.</ls> {#parRin#}\n<ls n=\"ṚV.\">8,5,32.</ls> {#druzad#}\n<ls n=\"ṚV.\">9,72,5.</ls> <ls>PAÑCAV. BR. 5,6,15.</ls> {#vaya^H puruzAda^H#} {%die Pfeile%}\n<ls>ṚV. 10,27,22.</ls> {#anu^ tvA\\ patnI^rhfzi\\taM vaya^Sca\\ viSve^ de\\vAso^ amada\\nnanu^ tvA#} nach dem <ab>Comm.</ab> {%die fliegenden%} <is>Marut</is>\n<ls n=\"ṚV.\">1,103,7.</ls> <ls n=\"ṚV.\">5,53,3.</ls> <ls>VS. 2,16.</ls> {#catuzpAdvO#}\n<ls>VOP. 23,6.</ls> {#nadeByA 'pi hradeByo 'pi pivantyanye vayaH payaH#}\n<ls>Spr. 1398.</ls> {#vIn#}\n<ls>BHAṬṬ. 9,24.</ls> {#BUtavigrahAH#}\n<ls>Spr. 3154.</ls> {#bahuvi jayati vanam#}\n<ls>UJJVAL.</ls> zu <ls>UṆĀDIS. 4,133.</ls>\n<div n=\"v\">— <ab>Vgl.</ab> {#rAjavi#} und 1. {#va