      "rdf:value": "<L>41400<pc>4-0362<k1>paYcadaSa<k2>paYcadaSa/\n{#paYcadaSa/#}¦ (von {#paYcadaSan#})\n<div n=\"1\"> 1) <lex>adj.</lex> <lex>f.</lex> {#I#}\n<div n=\"2\"> a) {%der fünfzehnte%}\n<ls>AV. 11,1,19.</ls>\n<ls>ŚAT. BR. 6,2,2,9.</ls> <ls n=\"ŚAT. BR.\">8,4,3,10.</ls> <ls n=\"ŚAT. BR.\">12,2,4,10.</ls>\n<ls>DAŚ. 2,66.</ls>\n<ls>VARĀH. BṚH. S. 6,4.</ls> {#arDa˚#} {%14%}(1/2)\n<ls>ŚĀṄKH. ŚR. 13,18,5.</ls>\n<div n=\"2\">— b) {%mit fünfzehn verbunden%}: {#˚SaM sahasram#} {%1015%}\n<ls>ŚĀṄKH. ŚR. 10,12,6. 14.</ls>\n<div n=\"2\">— c) {%aus fünfzehn bestehend, fünfzehn zählend%}: {#tI\\vraM su\\taM pa^Ycada\\SaM ni zi^Ycam#}\n<ls>ṚV. 10,27,2.</ls> {#u\\kTA#}\n<ls n=\"ṚV. 10,\">114,8.</ls> {#stoma#}\n<ls>P. 5,1,58</ls>, <is>Vārtt</is>. <ls n=\"P. 5,1,\">6.</ls> <ls n=\"P. 5,\">2,37</ls>, <is>Vārtt</is>. 4.\n<ls>VS. 9,34.</ls> <ls n=\"VS.\">10,11.</ls> <ls n=\"VS.\">13,35.</ls>\n<ls>AIT. BR. 4,31.</ls> <ls n=\"AIT. BR.\">8,4.</ls> <ls n=\"AIT. BR. 8,\">12.</ls>\n<ls>ŚAT. BR. 12,2,2,2.</ls> dem <is>Indra</is> vorzugsweise heilig\n<ls>NIR. 7,10.</ls> Mit Auslassung des Hauptworts\n<ls>VS. 21,24.</ls>\n<ls>AV. 8,9,15.</ls> <ls n=\"AV. 8,9,\">20.</ls>\n<ls>TBR. 1,5,10,2.</ls>\n<ls>ŚAT. BR. 1,3,5,7.</ls> <ls n=\"ŚAT. BR.\">8,5,1,10.</ls> <ls n=\"ŚAT. BR.\">12,2,4,10.</ls>\n<ls>VP. 42.</ls> — Hiervon abgeleitet\n<div n=\"2\"> d) {%den%} <is>Pañcadaśa-Stoma</is> {%enthaltend, — darstellend, — nachbildend, — damit verbunden <ab>u. s. w.</ab>%}: {#mADyaMdinaH pavamAnaH#}\n<ls>AIT. BR. 3,17.</ls> <ls n=\"AIT. BR. 3,\">41.</ls> {#kzatriyaH paYcadaSastomena Bavati#}\n<ls n=\"AIT. BR.\">7,23.</ls> {#candramAH#}\n<ls>TBR. 1,5,10,5.</ls> <ls n=\"TBR. 1,\">2,6,3.</ls>\n<ls>ŚAT. BR. 4,3,3,4.</ls> {#Ajya#}\n<ls n=\"ŚAT. BR.\">10,1,2,7.</ls> <ls n=\"ŚAT. BR.\">13,5,3,10.</ls> <ls n=\"ŚAT. BR. 13,5,\">4,9.</ls>\n<div n=\"1\">— 2) <lex>f.</lex> {#I#} (<ab>sc.</ab> {#tiTi#})\n<div n=\"2\"> a) {%der 15te Tag im Halbmonat, Vollmondstag%} oder {%Neumondstag%}\n<ls>AK. 1,1,3,7.</ls>\n<ls>H