      "csl:pageColumn": "1-137-c",
      "rdf:value": "<L>11685<pc>1-137-c<k1>aSmanta<k2>aSmanta\n{#aSmanta#}¦\n<div n=\"1\">— 1〉 *<lex>Adj.</lex>\n<div n=\"2\">— a〉 {%unheilvoll%}.\n<div n=\"2\">— b〉 {%schrankenlos%}.\n<div n=\"1\">— 2〉 <lex>m.</lex>\n<div n=\"2\">— a〉 *{%<bot>Bauhinia tomentosa</bot>%} <ls>RĀJAN. 9,40</ls>.\n<div n=\"2\">— b〉 <ab>N. pr.</ab> eines <is>Marutvant</is>.\n<div n=\"1\">— 3〉 *<lex>n.</lex>\n<div n=\"2\">— a〉 {%Ofen%}.\n<div n=\"2\">— b〉 {%Feld%}.\n<div n=\"2\">— c〉 {%Tod%}.\n<LEND>"
