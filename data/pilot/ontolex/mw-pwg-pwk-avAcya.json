      "csl:pageColumn": "1-0496",
      "rdf:value": "<L>6679<pc>1-0496<k1>avAcya<k2>avAcya\n{#avAcya#}¦ (3. {#a + vA˚#}) <lex>adj.</lex>\n<div n=\"1\"> 1) {%nicht anzureden%}: {#avAcyo dIkzito nAmnA#}\n<ls>M. 2,128.</ls>\n<div n=\"1\">— 2) {%was%} oder {%wovon nicht geredet werden darf%}\n<ls>AK. 1,1,5,21.</ls>\n<ls>H. 266.</ls> {#avAcyaM vadato jihvA kaTaM na patitA tava#}\n<ls>R. 5,56,81.</ls> {#vAcyAvAcyam#}\n<ls n=\"R.\">3,35,73.</ls> <ab>Vgl.</ab> {#avAcyadeSa#} .\n<div n=\"1\">— 3) {%nicht ausdrücklich bezeichnet%}; davon <ab>nom. abstr.</ab> {#avAcyatva#}\n<ls>SĀH. D. 30,20.</ls>\n<LEND>"
    },
