      "rdf:value": "<L>10842<pc>1-127-c<k1>avAcya<k2>avAcya\n{#avAcya#}¦ <lex>Adj.</lex>\n<div n=\"1\">— 1〉 {%nicht anzureden%}.\n<div n=\"1\">— 2〉 {%nicht zu sagen, — auszusprechen%} <ls n=\"Chr.\">126,10</ls>.\n<div n=\"1\">— 3〉 {%nicht unmittelbar ausgedrückt%}.\n<LEND>"
