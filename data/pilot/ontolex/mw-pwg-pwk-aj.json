      "csl:pageColumn": "1-0065",
      "rdf:value": "<L>871<pc>1-0065<k1>aj<k2>aj\n{#aj#}¦, {#a/jati#}\n<ls>DHĀTUP. 7,55.</ls> (<ab>med.</ab> kommt gleichfalls vor). Nach\n<ls>P. 2,4,56.</ls> <ls n=\"P. 2,4,\">57.</ls> fehlen die generellen Formen;\n<ls>SIDDH. K. 115,a.</ls> dagegen bildet: {#AjiTa, ajitA, ajizyati, AjIt#} (<ab>vgl.</ab>\n<ls>VOP. 8,60.</ls>), {#Ajizyat#} . Der Palatal geht nie in den Guttural über\n<ls>P. 7,3,60.</ls>\n<div n=\"1\"> 1) {%gehen%}\n<ls>DHĀTUP. 7,55.</ls>\n<ls>VOP. 8,58.</ls>\n<div n=\"1\">— 2) {%treiben%},\n<lang n=\"greek\">ἄγω</lang>, {%ago%}: {#aja^nti\\ vahni\\M sada^nA\\nyacCa^#}\n<ls>ṚV. 9,91,1.</ls> {#a\\smadA ni\\do va\\DEra^jeta durma\\tim#}\n<ls n=\"ṚV.\">1,129,6.</ls> <ls n=\"ṚV. 1,\">174,3.</ls> <ls n=\"ṚV.\">7,5,6.</ls> <ls>AV. 4,37,2.</ls> — {#Ajimaj#} {%einen Wettlauf anstellen%}\n<ls>ŚAT. BR. 2,4,3,4.</ls> <ls n=\"ŚAT. BR.\">5,1,1,3.</ls> <ab>pass.</ab>: {#kratvA\\ hi droRe^ a\\jyase 'gne^ vA\\jI na kftvya^H#}\n<ls>ṚV. 6,2,8</ls>, {#a\\jyamAna^H#} vom Pferde\n<ls n=\"ṚV.\">5,30,14.</ls>\n<div n=\"1\">— 3) {%schwingen, schleudern%}\n<ls>DHĀTUP.</ls> <ls>VOP.</ls> {#yABi\\H SArI\\rAja^ta\\M syUma^raSmaye#}\n<ls>ṚV. 1,112,16.</ls>\n<div n=\"p\">— {#apa#} {%wegtreiben%}: {#apa\\ tyaM pa^ripa\\nTina^maja#}\n<ls>ṚV. 1,42,3.</ls> <ls n=\"ṚV.\">10,3,1.</ls>\n<ls>AIT. BR. 5,28.</ls>\n<div n=\"p\">— {#aBi#} {%in Verbindung bringen, vereinigen%}: {#yatsa\\myaYcA^ miTu\\nAva\\ByajA^va#}\n<ls>ṚV. 1,179,3.</ls>\n<div n=\"p\">— {#ava#} {%hinabtreiben, hinabschaffen%}: {#Sro\\RAmeka^ uda\\kaM gAmavA^jati#}\n<ls>ṚV. 1,161,10.</ls>\n<div n=\"p\">— {#A#}\n<div n=\"1\"> 1) {%herbeitreiben, verschaffen%}: {#AjA^ na\\zwaM yaTA^ pa\\Sum#}\n<ls>ṚV. 1,23,13.</ls> <ls n=\"ṚV. 1,\">83,5.</ls> <ls n=\"ṚV.\">5,2,5.</ls> <ls n=\"ṚV.\">8,45,3.</ls>\n<ls>VS. 23,19.</ls>\n<ls>AIT. BR. 1,27.</ls> <ab>med.</ab>: {#A De\\numa^jaDvam#}\n<ls>ṚV. 6,48,11.</ls>\n<div n=\"1\">— 2) {%herbeitreiben%} (<ab>intrans.</ab>), {%fahrend herbeikommen%}: {#A sa^tva\\nEraja^ti#}\n<ls>ṚV. 5,37,4.</ls>\n<div n=\"p\">— {#aByA#} {%herantreiben%}: {#gAmaByAja SuklAm#}\n<ls>P. 8,1,8</ls>, <ab>Sch.</ab>\n<div n=\"p\">— {#ud#}\n<div n=\"1\"> 1) {%heraustreiben%}: {#gA udA^jat#}\n<ls>ṚV. 2,12,3.</ls> <ls n=\"ṚV. 2,\">14,3.</ls> <ls n=\"ṚV. 2,\">24,3.</ls> <ls n=\"ṚV.\">4,1,13.</ls>\n<ls>BṚH. ĀR. UP. 3,1,1.</ls> <ab>med.</ab>: {#u\\sriyA^ u\\dAja^ta#}\n<ls>ṚV. 1,112,12.</ls> <ls n=\"ṚV.\">3,44,5.</ls> {#sa etA gA udajatAm#}\n<ls>BṚH. ĀR. UP. 3,1,1.</ls> {#brahmagavIrudajase#}\n<ls n=\"BṚH. ĀR. UP.\">3,7,1.</ls>\n<div n=\"1\">— 2) {%ausziehen%}, <ab>med.</ab>: {#ucCu\\kramatka^majate si\\masmA^t#} {%er zieht jeglichem Ding das glänzende Gewand (Ansehen) aus%}\n<ls>ṚV. 1,95,7.</ls>\n<div n=\"p\">— {#upa#} {%herantreiben%}: {#a\\gnire^nA u\\pAja^tu#}\n<ls>ṚV. 10,19,2.</ls> <ab>med.</ab>: {#bfha\\spati^rvi\\SvarU^pA\\mupAjata#}\n<ls n=\"ṚV.\">1,161,6.</ls> {#pfSni^me\\tAmupA^je#}\n<ls>AV. 5,11,2.</ls>\n<div n=\"p\">— {#nis#} {%austreiben, herausbringen%}: {#nirvo^ go\\zWAda^jAmasi#}\n<ls>AV. 2,14,2.</ls> {#niH parva^tasya\\ gA A^jaH#}\n<ls>ṚV. 8,3,19.</ls> {#ni\\raje\\#} (<ab>dat.</ab> <ab>inf.</ab>) {#gAH#}\n<ls n=\"ṚV.\">3,30,10.</ls>\n<div n=\"p\">— {#vi#} {%auseinandertreiben, durchfurchen%}: {#vi yadajrA\\~ aja^Ta\\ nAva^ IM yaTA#}\n<ls>ṚV. 5,54,4.</ls>\n<div n=\"p\">— {#sam#}\n<div n=\"1\"> 1) {%zusammentreiben, gewinnen%}: {#kzAme^va na\\H sama^jata\\M rajA^Msi#}\n<ls>ṚV. 2,39,7.</ls>\n[Page1-0066]\n{#sama^jAti\\ veda^H#}\n<ls n=\"ṚV.\">5,2,12.</ls> <ls n=\"ṚV. 5,\">34,7.</ls> <ls n=\"ṚV.\">1,33,3.</ls>\n<div n=\"1\">— 2) {%zusammentreiben, zu Paaren treiben%}: {#spfDa\\H sama^jA sa\\matsu^#}\n<ls>ṚV. 6,25,9.</ls>\n<div n=\"1\">— 3) {%feindlich zusammenbringen%}: {#saM jA\\miBi\\ryatsa\\majA^ti mI\\|e 'jA^miBirvA#}\n<ls>ṚV. 1,100,11.</ls> {#yatsa\\majA^si\\ SarDa^taH#}\n<ls n=\"ṚV.\">7,32,7.</ls>\n<LEND>"
    },
