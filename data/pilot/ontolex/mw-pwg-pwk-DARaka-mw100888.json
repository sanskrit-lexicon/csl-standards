      "csl:pageColumn": "3-0930",
      "rdf:value": "<L>36489<pc>3-0930<k1>DARaka<k2>DA/Raka\n{#DA/Raka#}¦\n<ls>UṆĀDIS. 3,83.</ls>\n<div n=\"1\"> 1) <lex>m.</lex> {%Theil eines%} <is>Dīnāra</is>\n<ls>UJJVAL.</ls> {#DAnaka#} {%eine Kupfermünze im Werthe von ungefähr 2 Pence%}\n<ls>HAUGHT.</ls>\n<div n=\"1\">— 2) <lex>f.</lex> {#DA/RikA#} <ab>viell.</ab> <ab>Bez.</ab> {%der weiblichen Scham%}: {#Aha^taM ga\\Be paso\\ nija^lgulIti\\ DARi^kA#}\n<ls>TS. 7,4,19,3</ls> (<ab>vgl.</ab>\n<ls>VS. 23,22</ls>). {#va\\yaM na vi^dma\\ yo mf\\gaH SI\\rzRA hara^ti\\ #}\n[Page3-0931]\n{# DARi^kAm#}\n<ls>AV. 20,136,10.</ls>\n<LEND>"
    },
