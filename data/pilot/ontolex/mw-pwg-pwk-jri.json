      "rdf:value": "<L>80855<pc>428,1<k1>jri<k2>jri<h>2<e>3\r\n<hom>2.</hom> <s>jri</s> ¦ See <s>uru-</s> and <s>pari-jri/</s>.\r\n<LEND>"
    },
    {
      "@id": "https://sanskrit-lexicon.github.io/csl-standards/id/case/mw-pwg-pwk%3Ajri#record-pwg",
      "@type": "csl:SourceRecord",
