@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix lexicog: <http://www.w3.org/ns/lemon/lexicog#> .
@prefix frac: <http://www.w3.org/ns/lemon/frac#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix csl: <https://sanskrit-lexicon.github.io/csl-standards/ns#> .

csl:LexicalEntryShape
  a sh:NodeShape ;
  sh:targetClass ontolex:LexicalEntry ;
  sh:property [
    sh:path ontolex:canonicalForm ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path csl:sourceRecord ;
    sh:minCount 3
  ] ;
  sh:property [
    sh:path frac:attestation ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path csl:profileVersion ;
    sh:minCount 1 ;
    sh:hasValue "ontolex-frac-profile-v0.1"
  ] ;
  sh:property [
    sh:path csl:validationScope ;
    sh:minCount 1 ;
    sh:hasValue "full-ontolex-shacl-profile"
  ] .

csl:SourceRecordShape
  a sh:NodeShape ;
  sh:targetClass csl:SourceRecord ;
  sh:property [ sh:path dct:source ; sh:minCount 1 ] ;
  sh:property [ sh:path csl:dictionary ; sh:minCount 1 ] ;
  sh:property [ sh:path csl:recordNumber ; sh:minCount 1 ] .

csl:AttestationShape
  a sh:NodeShape ;
  sh:targetClass frac:Attestation ;
  sh:property [ sh:path frac:attests ; sh:minCount 1 ] ;
  sh:property [ sh:path frac:evidence ; sh:minCount 1 ] ;
  sh:property [ sh:path prov:wasDerivedFrom ; sh:minCount 1 ] ;
  sh:property [ sh:path csl:evidenceType ; sh:minCount 1 ] ;
  # csl: evidence-class extension (EXTENSION_PROPOSAL.md §1): every attestation
  # carries a sub-typed evidence class; a coordinate-bearing one parses it.
  sh:property [
    sh:path csl:evidenceClass ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "textual" "hedge" "kosha" "editorial" )
  ] ;
  sh:property [ sh:path csl:citedRange ; sh:maxCount 1 ] ;
  sh:property [ sh:path csl:citedWork ; sh:maxCount 1 ] .

# Multi-resource (OntoLex-Lexicog): per source dictionary that has senses, a
# lexicog:LexicographicResource (the dictionary) containing a lexicog:Entry (its
# article for this lemma) that describes the shared lexical entry and lists senses.
csl:LexicographicResourceShape
  a sh:NodeShape ;
  sh:targetClass lexicog:LexicographicResource ;
  sh:property [ sh:path dct:source ; sh:minCount 1 ] ;
  sh:property [ sh:path csl:dictionary ; sh:minCount 1 ] ;
  sh:property [ sh:path lexicog:entry ; sh:minCount 1 ] .

csl:LexicographicEntryShape
  a sh:NodeShape ;
  sh:targetClass lexicog:Entry ;
  sh:property [ sh:path lexicog:describes ; sh:minCount 1 ; sh:maxCount 1 ] ;
  sh:property [ sh:path lexicog:component ; sh:minCount 1 ] .

# Continuation-parent recovery status (EXTENSION_PROPOSAL §4): a reconstructed
# parent carries an explicit recovery status, never asserted as if printed.
csl:ContinuationRelationShape
  a sh:NodeShape ;
  sh:targetClass csl:ContinuationRelation ;
  sh:property [ sh:path csl:relatesEntry ; sh:minCount 1 ] ;
  sh:property [
    sh:path csl:recoveryStatus ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "recovered" "conjectured" "unresolved" )
  ] .

# Source-collapse lineage (EXTENSION_PROPOSAL §4a): an explicit, queryable edge
# for the PWG → PWK → MW evidence collapse, carrying retained/dropped counts.
csl:LineageRelationShape
  a sh:NodeShape ;
  sh:targetClass csl:LineageRelation ;
  sh:property [ sh:path csl:relatesEntry ; sh:minCount 1 ] ;
  sh:property [ sh:path csl:lineageFrom ; sh:minCount 1 ] ;
  sh:property [ sh:path csl:lineageTo ; sh:minCount 1 ] ;
  sh:property [
    sh:path csl:transition ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "abridgement" "recomposition" )
  ] ;
  sh:property [ sh:path csl:droppedCitationCount ; sh:minCount 1 ; sh:maxCount 1 ] .

# Lexical sense (added in v0.8.0): each sense carries at least one definition (a
# language-tagged literal — one per language for the trilingual FRI senses), a
# single source dictionary, and a back-pointer to the entry. csl:senseKind, when
# present, is "cross-reference". The source dictionary is intentionally left an open
# string so the dictionary registry can add a dictionary without touching this profile.
csl:LexicalSenseShape
  a sh:NodeShape ;
  sh:targetClass ontolex:LexicalSense ;
  sh:property [
    sh:path skos:definition ;
    sh:minCount 1 ;
    sh:nodeKind sh:Literal
  ] ;
  sh:property [
    sh:path csl:sourceDictionary ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path ontolex:isSenseOf ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path csl:senseKind ;
    sh:maxCount 1 ;
    sh:in ( "cross-reference" )
  ] .
